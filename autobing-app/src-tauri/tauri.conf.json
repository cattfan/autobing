{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "autobing-app",
  "version": "0.1.1",
  "identifier": "com.autobing.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "AutoBing",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "resources": [
      "bin/worker_api.exe",
      "bin/browser_scanner.exe"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJCOTI5QTgwRDNFNzFGMDcKUldRSEgrZlRnSnFTdTF2am1hY09lUE8ra3JNSUNuZ1ErY3JzVlQycTlSbk56MzJwYXJQUVJxK3oK",
      "endpoints": [
        "https://raw.githubusercontent.com/cattfan/autobing/main/update.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
